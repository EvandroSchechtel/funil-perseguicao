// Prisma Schema — Funil Perseguição

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  super_admin
  admin
  operador
  viewer
  cliente
}

enum TipoDemanda {
  nova_campanha
  ajuste_funil
  relatorio_customizado
  suporte_tecnico
  outro
}

enum StatusDemanda {
  aberta
  em_analise
  em_execucao
  aguardando_cliente
  concluida
  cancelada
}

enum PrioridadeDemanda {
  baixa
  normal
  alta
  urgente
}

enum Status {
  ativo
  inativo
}

enum LeadStatus {
  pendente
  processando
  sucesso
  falha
  sem_optin
}

enum AgentSessaoStatus {
  executando
  concluido
  erro
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model Usuario {
  id                    String    @id @default(uuid())
  nome                  String
  email                 String    @unique
  senha                 String
  role                  Role      @default(viewer)
  avatar_url            String?
  status                Status    @default(ativo)
  ultimo_login          DateTime?
  force_password_change Boolean   @default(false)
  cliente_id            String?   @db.Uuid  // preenchido quando role=cliente
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  refresh_tokens        RefreshToken[]
  password_reset_tokens PasswordResetToken[]
  clientes              Cliente[]            @relation("ClienteCriador")
  cliente_vinculado     Cliente?             @relation("ClientePortalUsuarios", fields: [cliente_id], references: [id])
  contas_manychat       ContaManychat[]
  campanhas             Campanha[]
  webhooks              Webhook[]
  agent_sessoes         AgentSessao[]
  instancias_zapi       InstanciaZApi[]
  demandas_criadas      Demanda[]            @relation("DemandaCriador")
  demandas_atribuidas   Demanda[]            @relation("DemandaAtribuido")

  @@map("usuarios")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  usuario_id String
  usuario    Usuario   @relation(fields: [usuario_id], references: [id])
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  token      String    @unique
  usuario_id String
  usuario    Usuario   @relation(fields: [usuario_id], references: [id])
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@map("password_reset_tokens")
}

// ── Clientes ──────────────────────────────────────────────────────────────────

model Cliente {
  id                      String         @id @default(uuid()) @db.Uuid
  nome                    String
  email                   String?
  telefone                String?
  created_by              String
  usuario                 Usuario        @relation("ClienteCriador", fields: [created_by], references: [id])
  // WhatsApp para notificações
  grupo_wa_id             String?        // ID do grupo WA do cliente
  grupo_wa_nome           String?        // nome do grupo (cache)
  instancia_zapi_notif_id String?        // instância Z-API usada para notificar
  instancia_zapi_notif    InstanciaZApi? @relation("ClienteInstanciaNotif", fields: [instancia_zapi_notif_id], references: [id])
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt
  deleted_at              DateTime?

  contas_manychat  ContaManychat[]
  campanhas        Campanha[]
  instancias_zapi  InstanciaZApi[]  @relation("InstanciaZApiCliente")
  usuarios_portal  Usuario[]        @relation("ClientePortalUsuarios")
  demandas         Demanda[]

  @@map("clientes")
}

// ── Manychat ──────────────────────────────────────────────────────────────────

model ContaManychat {
  id                  String    @id @default(uuid())
  nome                String
  api_key             String
  page_id             String?
  page_name           String?
  status              Status    @default(ativo)
  ultimo_sync         DateTime?
  whatsapp_field_id   Int?      // Manychat field ID for [esc]whatsapp-id
  limite_diario       Int?      // max sends per day (null = unlimited)
  created_by          String
  usuario             Usuario   @relation(fields: [created_by], references: [id])
  cliente_id          String?   @db.Uuid
  cliente             Cliente?  @relation(fields: [cliente_id], references: [id])
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  webhook_flows        WebhookFlow[]
  contatos_vinculados  ContatoConta[]
  grupos_monitoramento GrupoMonitoramento[]
  uso_diario           ContaUsoDiario[]

  @@map("contas_manychat")
}

model ContaUsoDiario {
  id         String        @id @default(uuid())
  conta_id   String
  conta      ContaManychat @relation(fields: [conta_id], references: [id])
  data       DateTime      @db.Date   // day in BRT (UTC-3)
  total      Int           @default(0)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  @@unique([conta_id, data])
  @@map("conta_uso_diario")
}

// ── Campanhas ─────────────────────────────────────────────────────────────────

model Campanha {
  id          String    @id @default(uuid())
  nome        String
  descricao   String?
  status      Status    @default(ativo)
  data_inicio DateTime?
  data_fim    DateTime?
  created_by  String
  usuario     Usuario   @relation(fields: [created_by], references: [id])
  cliente_id  String?   @db.Uuid
  cliente     Cliente?  @relation(fields: [cliente_id], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  webhooks             Webhook[]
  leads                Lead[]
  grupos_monitoramento GrupoMonitoramento[]

  @@map("campanhas")
}

// ── Webhooks ──────────────────────────────────────────────────────────────────

model Webhook {
  id          String    @id @default(uuid())
  nome        String
  token       String    @unique @default(uuid())
  campanha_id String?
  campanha    Campanha? @relation(fields: [campanha_id], references: [id])
  status      Status    @default(ativo)
  created_by  String
  usuario     Usuario   @relation(fields: [created_by], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  webhook_flows WebhookFlow[]
  leads         Lead[]

  @@map("webhooks")
}

// Cada item do rodízio: um flow em uma conta Manychat específica
model WebhookFlow {
  id             String        @id @default(uuid())
  webhook_id     String
  webhook        Webhook       @relation(fields: [webhook_id], references: [id])
  conta_id       String
  conta          ContaManychat @relation(fields: [conta_id], references: [id])
  flow_ns        String
  flow_nome      String?
  ordem          Int           @default(0)
  total_enviados Int           @default(0)
  status         Status        @default(ativo)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  deleted_at     DateTime?

  leads Lead[]

  @@map("webhook_flows")
}

// ── Contatos ──────────────────────────────────────────────────────────────────
// Identidade única por telefone — pessoa, independente de campanha ou conta

model Contato {
  id         String   @id @default(uuid())
  telefone   String   @unique  // chave natural — o número é a identidade
  nome       String
  email      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  leads            Lead[]
  contas_vinculadas ContatoConta[]

  @@map("contatos")
}

// Vínculo entre um Contato e uma ContaManychat específica
// Armazena o subscriber_id para aquela conta
model ContatoConta {
  id            String        @id @default(uuid())
  contato_id    String
  contato       Contato       @relation(fields: [contato_id], references: [id])
  conta_id      String
  conta         ContaManychat @relation(fields: [conta_id], references: [id])
  campanha_id   String?       // campanha que originou o vínculo
  subscriber_id String?       // ID do subscriber nessa conta Manychat
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt

  @@unique([contato_id, conta_id])
  @@map("contato_contas")
}

// ── Leads ─────────────────────────────────────────────────────────────────────

model Lead {
  id              String       @id @default(uuid())
  contato_id      String
  contato         Contato      @relation(fields: [contato_id], references: [id])
  webhook_id      String
  webhook         Webhook      @relation(fields: [webhook_id], references: [id])
  campanha_id     String?
  campanha        Campanha?    @relation(fields: [campanha_id], references: [id])
  webhook_flow_id String?
  webhook_flow    WebhookFlow? @relation(fields: [webhook_flow_id], references: [id])
  nome            String       // snapshot do nome no momento do cadastro
  telefone        String       // snapshot do telefone
  email           String?
  subscriber_id   String?      // subscriber_id na conta que processou
  flow_executado  String?
  conta_nome      String?
  status          LeadStatus   @default(pendente)
  erro_msg        String?
  tentativas      Int          @default(0)
  processado_at   DateTime?
  grupo_entrou_at DateTime?    // preenchido quando detectado no grupo da campanha
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  tentativas_hist LeadTentativa[]
  entradas_grupo  EntradaGrupo[]

  @@unique([webhook_id, contato_id])  // um lead por webhook+contato
  @@map("leads")
}

model LeadTentativa {
  id            String    @id @default(uuid())
  lead_id       String
  lead          Lead      @relation(fields: [lead_id], references: [id])
  numero        Int
  status        String    // "sucesso" | "falha" | "sem_optin"
  erro_msg      String?
  subscriber_id String?
  flow_ns       String?
  conta_nome    String?
  executado_at  DateTime  @default(now())

  @@map("lead_tentativas")
}

// ── Z-API ─────────────────────────────────────────────────────────────────────

model InstanciaZApi {
  id            String    @id @default(uuid())
  nome          String
  instance_id   String                           // ID da instância no Z-API
  token         String                           // Token da instância Z-API
  client_token  String                           // Header Client-Token para chamadas Z-API
  webhook_token String    @unique @default(uuid()) // token da URL /api/webhook/zapi/[token]
  status        Status    @default(ativo)
  cliente_id    String?   @db.Uuid
  cliente       Cliente?  @relation("InstanciaZApiCliente", fields: [cliente_id], references: [id])
  created_by    String
  usuario       Usuario   @relation(fields: [created_by], references: [id])
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  grupos          GrupoMonitoramento[]
  clientes_notif  Cliente[]            @relation("ClienteInstanciaNotif")

  @@map("instancias_zapi")
}

model GrupoMonitoramento {
  id                  String        @id @default(uuid())
  instancia_id        String
  instancia           InstanciaZApi @relation(fields: [instancia_id], references: [id])
  campanha_id         String
  campanha            Campanha      @relation(fields: [campanha_id], references: [id])
  conta_manychat_id   String
  conta_manychat      ContaManychat @relation(fields: [conta_manychat_id], references: [id])
  nome_filtro         String        // match case-insensitive contains no chatName do Z-API
  grupo_wa_id         String?       // ID do grupo WhatsApp — preenchido no 1º match
  tag_manychat_id     Int           // ID da tag no Manychat
  tag_manychat_nome   String        // nome da tag (para exibição)
  status              Status        @default(ativo)
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  entradas EntradaGrupo[]

  @@unique([campanha_id, instancia_id])
  @@map("grupos_monitoramento")
}

model EntradaGrupo {
  id            String             @id @default(uuid())
  grupo_id      String
  grupo         GrupoMonitoramento @relation(fields: [grupo_id], references: [id])
  lead_id       String?
  lead          Lead?              @relation(fields: [lead_id], references: [id])
  contato_id    String?
  telefone      String             // telefone normalizado (sem +, só dígitos)
  nome_whatsapp String?
  grupo_wa_id   String             // ID do grupo WhatsApp no evento
  grupo_wa_nome String             // nome do grupo no evento
  subscriber_id String?
  tag_aplicada  Boolean            @default(false)
  tag_erro      String?
  entrou_at     DateTime           @default(now())

  @@unique([grupo_id, telefone])   // upsert em caso de re-entrada
  @@map("entradas_grupo")
}

// ── Portal do Cliente — Demandas ──────────────────────────────────────────────

model Demanda {
  id                String            @id @default(uuid())
  titulo            String
  descricao         String
  tipo              TipoDemanda
  status            StatusDemanda     @default(aberta)
  prioridade        PrioridadeDemanda @default(normal)
  cliente_id        String            @db.Uuid
  cliente           Cliente           @relation(fields: [cliente_id], references: [id])
  criado_por        String
  criador           Usuario           @relation("DemandaCriador", fields: [criado_por], references: [id])
  atribuido_a       String?
  responsavel       Usuario?          @relation("DemandaAtribuido", fields: [atribuido_a], references: [id])
  // WhatsApp
  grupo_wa_id       String?           // grupo WA onde a demanda foi anunciada
  wa_msg_id_inicio  String?           // ID da 1ª mensagem WA (threading)
  // Agente IA
  agente_ativo      Boolean           @default(false)
  agente_sessao_id  String?
  agente_sessao     AgentSessao?      @relation(fields: [agente_sessao_id], references: [id])
  resolvido_at      DateTime?
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  comentarios   ComentarioDemanda[]
  mensagens_wa  MensagemWaDemanda[]
  gatilhos      GatilhoAgente[]

  @@map("demandas")
}

model ComentarioDemanda {
  id         String   @id @default(uuid())
  demanda_id String
  demanda    Demanda  @relation(fields: [demanda_id], references: [id])
  autor_id   String   // usuario.id (admin ou cliente)
  texto      String
  interno    Boolean  @default(false) // true = só equipe interna vê
  created_at DateTime @default(now())

  @@map("comentarios_demanda")
}

// Log de todas as mensagens WA — contexto para o agente IA
model MensagemWaDemanda {
  id                    String   @id @default(uuid())
  demanda_id            String
  demanda               Demanda  @relation(fields: [demanda_id], references: [id])
  direcao               String   // "saida" | "entrada"
  texto                 String
  autor_nome            String?
  autor_wa_id           String?
  wa_msg_id             String?  // ID no Z-API (para threading)
  processado_por_agente Boolean  @default(false)
  created_at            DateTime @default(now())

  @@map("mensagens_wa_demanda")
}

// Gatilho para o agente IA — criado quando @agente é mencionado no grupo
model GatilhoAgente {
  id          String       @id @default(uuid())
  demanda_id  String?
  demanda     Demanda?     @relation(fields: [demanda_id], references: [id])
  grupo_wa_id String
  mensagem    String
  autor_wa_id String
  wa_msg_id   String
  status      String       @default("pendente") // pendente | processando | concluido | erro
  erro        String?
  sessao_id   String?
  sessao      AgentSessao? @relation(fields: [sessao_id], references: [id])
  created_at  DateTime     @default(now())

  @@map("gatilhos_agente")
}

// ── Agent ─────────────────────────────────────────────────────────────────────

model AgentSessao {
  id         String            @id @default(uuid())
  usuario_id String
  usuario    Usuario           @relation(fields: [usuario_id], references: [id])
  prompt     String
  resposta   String?
  status     AgentSessaoStatus @default(executando)
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt

  acoes           AgentAcao[]
  demandas        Demanda[]
  gatilhos_agente GatilhoAgente[]

  @@map("agent_sessoes")
}

model AgentAcao {
  id         String      @id @default(uuid())
  sessao_id  String
  sessao     AgentSessao @relation(fields: [sessao_id], references: [id])
  tool_name  String
  args       Json
  resultado  Json?
  erro       String?
  ordem      Int
  created_at DateTime    @default(now())

  @@map("agent_acoes")
}
