// Prisma Schema — Funil Perseguição

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  super_admin
  admin
  operador
  viewer
}

enum Status {
  ativo
  inativo
}

enum LeadStatus {
  pendente
  processando
  sucesso
  falha
}

enum AgentSessaoStatus {
  executando
  concluido
  erro
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model Usuario {
  id                    String    @id @default(uuid())
  nome                  String
  email                 String    @unique
  senha                 String
  role                  Role      @default(viewer)
  avatar_url            String?
  status                Status    @default(ativo)
  ultimo_login          DateTime?
  force_password_change Boolean   @default(false)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  deleted_at            DateTime?

  refresh_tokens        RefreshToken[]
  password_reset_tokens PasswordResetToken[]
  clientes              Cliente[]
  contas_manychat       ContaManychat[]
  campanhas             Campanha[]
  webhooks              Webhook[]
  agent_sessoes         AgentSessao[]

  @@map("usuarios")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  usuario_id String
  usuario    Usuario   @relation(fields: [usuario_id], references: [id])
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  token      String    @unique
  usuario_id String
  usuario    Usuario   @relation(fields: [usuario_id], references: [id])
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@map("password_reset_tokens")
}

// ── Clientes ──────────────────────────────────────────────────────────────────

model Cliente {
  id         String    @id @default(uuid())
  nome       String
  email      String?
  telefone   String?
  created_by String
  usuario    Usuario   @relation(fields: [created_by], references: [id])
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  contas_manychat ContaManychat[]
  campanhas       Campanha[]

  @@map("clientes")
}

// ── Manychat ──────────────────────────────────────────────────────────────────

model ContaManychat {
  id          String    @id @default(uuid())
  nome        String
  api_key     String
  page_id     String?
  page_name   String?
  status      Status    @default(ativo)
  ultimo_sync DateTime?
  created_by  String
  usuario     Usuario   @relation(fields: [created_by], references: [id])
  cliente_id  String?
  cliente     Cliente?  @relation(fields: [cliente_id], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  webhook_flows WebhookFlow[]

  @@map("contas_manychat")
}

// ── Campanhas ─────────────────────────────────────────────────────────────────

model Campanha {
  id          String    @id @default(uuid())
  nome        String
  descricao   String?
  status      Status    @default(ativo)
  data_inicio DateTime?
  data_fim    DateTime?
  created_by  String
  usuario     Usuario   @relation(fields: [created_by], references: [id])
  cliente_id  String?
  cliente     Cliente?  @relation(fields: [cliente_id], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  webhooks Webhook[]
  leads    Lead[]

  @@map("campanhas")
}

// ── Webhooks ──────────────────────────────────────────────────────────────────

model Webhook {
  id          String    @id @default(uuid())
  nome        String
  token       String    @unique @default(uuid())
  campanha_id String?
  campanha    Campanha? @relation(fields: [campanha_id], references: [id])
  status      Status    @default(ativo)
  created_by  String
  usuario     Usuario   @relation(fields: [created_by], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  webhook_flows WebhookFlow[]
  leads         Lead[]

  @@map("webhooks")
}

// Cada item do rodízio: um flow em uma conta Manychat específica
model WebhookFlow {
  id             String        @id @default(uuid())
  webhook_id     String
  webhook        Webhook       @relation(fields: [webhook_id], references: [id])
  conta_id       String
  conta          ContaManychat @relation(fields: [conta_id], references: [id])
  flow_ns        String
  flow_nome      String?
  ordem          Int           @default(0)
  total_enviados Int           @default(0)
  status         Status        @default(ativo)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  deleted_at     DateTime?

  leads Lead[]

  @@map("webhook_flows")
}

// ── Leads ─────────────────────────────────────────────────────────────────────

model Lead {
  id              String      @id @default(uuid())
  webhook_id      String
  webhook         Webhook     @relation(fields: [webhook_id], references: [id])
  campanha_id     String?
  campanha        Campanha?   @relation(fields: [campanha_id], references: [id])
  webhook_flow_id String?
  webhook_flow    WebhookFlow? @relation(fields: [webhook_flow_id], references: [id])
  nome            String
  telefone        String
  email           String?
  subscriber_id   String?     // ID do subscriber no Manychat
  flow_executado  String?     // flow_ns que foi disparado
  conta_nome      String?     // nome da conta Manychat que recebeu
  status          LeadStatus  @default(pendente)
  erro_msg        String?
  tentativas      Int         @default(0)
  manychat_log    Json?       // log detalhado do que aconteceu no Manychat
  processado_at   DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  @@map("leads")
}

// ── Agent ─────────────────────────────────────────────────────────────────────

model AgentSessao {
  id         String            @id @default(uuid())
  usuario_id String
  usuario    Usuario           @relation(fields: [usuario_id], references: [id])
  prompt     String
  resposta   String?
  status     AgentSessaoStatus @default(executando)
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt

  acoes AgentAcao[]

  @@map("agent_sessoes")
}

model AgentAcao {
  id         String      @id @default(uuid())
  sessao_id  String
  sessao     AgentSessao @relation(fields: [sessao_id], references: [id])
  tool_name  String
  args       Json
  resultado  Json?
  erro       String?
  ordem      Int
  created_at DateTime    @default(now())

  @@map("agent_acoes")
}
